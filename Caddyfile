# OMNISCIENT gateway config
#
# ─────────────────────────────────────────────────────────────────────────────
# SEC-C1 (fixed): a previous named matcher keyed off the XTransformPort
# query parameter and forwarded the request to localhost:<that port>. That
# turned the public :81 listener into an OPEN INTERNAL SSRF PROXY: anyone
# on the internet could reach Redis (6379), Postgres (5432), the scheduler
# status server (3042), or any other localhost-bound service by just
# appending ?XTransformPort=<n> to a request.
#
# A full audit of the codebase (grep for "XTransformPort" across src/,
# mini-services/, and scripts/) confirmed that NO application code uses
# this query parameter:
#   - The scheduler mini-service (port 3042) runs its own self-contained
#     Bun HTTP server and polls the app directly; it is never reached
#     through this gateway.
#   - The Next.js app drives its own /api/scheduler/tick in-process via
#     src/instrumentation.ts (setInterval -> http://localhost:${PORT}/...).
# So the matcher served no verified purpose and has been removed entirely.
#
# Defense in depth: any request that still carries an XTransformPort query
# parameter is now explicitly rejected with HTTP 403 *before* it can reach
# any forwarding logic, so the SSRF surface stays closed even if a proxy
# rule is accidentally reintroduced later.
#
# ─────────────────────────────────────────────────────────────────────────────
# SEC-C2 (fixed): port :81 previously had NO authentication on any route.
# The Next.js app has its own HMAC-signed cookie auth (src/middleware.ts),
# but the gateway itself was an open proxy — if the app middleware were
# ever bypassed (bug, misconfigured new route, regex edge case), every
# internal route (settings, API keys, signals, portfolio) would be exposed.
#
# Fix: HTTP Basic Auth is now required on ALL proxied routes except a
# minimal allowlist of routes that *cannot* function with gateway auth:
#   - /lock              (the login page — users must reach it to log in)
#   - /_next/*           (static assets so /lock can render)
#   - /api/auth/login    (the login endpoint itself)
#   - /api/auth/logout   (logout)
#   - /api/health        (automated health checks — can't send credentials)
#   - /api/telegram/webhook (Telegram servers call this inbound; they
#                           cannot send Basic Auth credentials)
#   - /logo.svg /robots.txt /favicon* (static assets)
#
# Everything else — /, /api/settings, /api/signals, /api/portfolio,
# /api/setup, /api/telegram/setup, /api/scheduler/tick, all dashboard
# pages — requires Basic Auth at the gateway AND cookie auth at the app.
# This is defense in depth: an attacker must breach BOTH layers.
#
# The scheduler tick (/api/scheduler/tick) is NOT allowlisted here because
# no caller goes through :81 — the in-process tick (instrumentation.ts)
# and the mini-service both call localhost:3000/7860 directly.
#
# Credentials (default):  admin / omniscient
# These match the default APP_PASSWORD (see start.sh). For production,
# regenerate the hash and update it below:
#   bun -e 'console.log(await Bun.password.hash("NEW_PASSWORD", "bcrypt"))'
# The username can also be changed on the `basicauth` line below.
#
# ─────────────────────────────────────────────────────────────────────────────
# SEC-C3 (fixed): all traffic on :81 was plaintext HTTP, including
# sensitive headers like Authorization and X-Cron-Secret. While Hugging
# Face Spaces terminates TLS at their edge (https://<space>.hf.space),
# the in-container hop from the HF edge to Caddy (:81) and from Caddy to
# Next.js (:3000) was plaintext — a compromised sidecar or co-located
# process could sniff credentials.
#
# Fix: added a second TLS-terminated HTTPS listener on :8443 using Caddy's
# internal CA (tls internal — self-signed, trusted inside the container).
# The HTTP :81 listener now REDIRECTS all non-health traffic to HTTPS :8443.
# Sensitive headers (Authorization, X-Cron-Secret) only travel on the
# encrypted :8443 hop.
#
# Architecture:
#   :81  (HTTP)  — HF edge forwards here.
#                  /api/health + /api/telegram/webhook stay HTTP (HF health
#                  check needs 200; Telegram webhook can't follow redirects
#                  reliably for POST). Everything else 308-redirects to :8443.
#   :8443 (HTTPS, tls internal) — carries basicauth + reverse_proxy.
#                  All sensitive-header traffic lands here.
#
# Why /api/health stays on :81: HF's platform health check does
# HEAD /api/health on the container port and expects 200 (the "FC 412"
# error in start.sh = "port 81 health check failed"). A redirect would
# make HF mark the Space unhealthy and kill it.
#
# Why /api/telegram/webhook stays on :81: Telegram sends POST requests
# inbound; redirecting POSTs is unreliable (clients may drop the body or
# fail to follow). The webhook carries no credentials — it's an inbound
# message receiver, not a credential-bearing call.
#
# The 308 (Permanent) redirect is used instead of 301 because 308
# preserves the method (POST stays POST) per RFC 7538, so any client
# that does follow it won't be broken.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP listener :81 — health + webhook direct, everything else redirects ──
:81 {
	@ssrf_attempt {
		query XTransformPort=*
	}
	handle @ssrf_attempt {
		respond "Forbidden" 403
	}

	# Routes that MUST stay on plaintext HTTP (see SEC-C3 comment above).
	@http_ok {
		path /api/health /api/telegram/webhook
	}
	handle @http_ok {
		reverse_proxy localhost:3000 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}

	# Everything else: 308-redirect to the HTTPS listener.
	# Sensitive headers (Authorization, X-Cron-Secret) will only be sent
	# by the client AFTER the redirect, on the encrypted :8443 hop.
	handle {
		redir https://{host}:8443{uri} 308
	}
}

# ── HTTPS listener :8443 — TLS-terminated, basicauth + reverse_proxy ──
# tls internal uses Caddy's built-in CA (self-signed). The cert is
# generated on first start and stored in Caddy's data dir.
:8443 {
	tls internal

	@ssrf_attempt {
		query XTransformPort=*
	}
	handle @ssrf_attempt {
		respond "Forbidden" 403
	}

	# Public routes — NO gateway auth (login flow, assets).
	# /api/health and /api/telegram/webhook are served on :81 directly,
	# but also allowlisted here in case a client reaches :8443 for them.
	@public {
		path /lock /api/auth/login /api/auth/logout /api/health /api/telegram/webhook /logo.svg /robots.txt
		path /_next/*
		path /favicon*
	}
	handle @public {
		reverse_proxy localhost:3000 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}

	# Everything else — require HTTP Basic Auth at the gateway (SEC-C2).
	# The app's own cookie auth (src/middleware.ts) runs as a second layer.
	handle {
		basicauth {
			admin `$2b$10$xVqp/Ogg.v/ob4ffGEroI.Me15e1PAR3CnBL1SQeV.DUW.PKFWHCC`
		}
		reverse_proxy localhost:3000 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}
}
